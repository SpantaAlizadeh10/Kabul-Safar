{
  "name": "kabul-safar",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix kabul-safar-website",
    "dev:kill": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev": "npm run dev --prefix kabul-safar-website",
    "dev:fresh": "npm run dev:kill && npm run dev",
    "build": "npm run build --prefix kabul-safar-website",
    "start": "npm run start --prefix kabul-safar-website",
    "lint": "npm run lint --prefix kabul-safar-website"
  }
}
