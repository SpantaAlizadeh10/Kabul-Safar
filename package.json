{
  "name": "kabul-safar",
  "private": true,
  "workspaces": [
    "kabul-safar-website"
  ],
  "scripts": {
    "install": "npm --prefix kabul-safar-website install",
    "install:all": "npm install --prefix kabul-safar-website",
    "dev:kill": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev": "npm --prefix kabul-safar-website run dev",
    "dev:fresh": "npm run dev:kill && npm run dev",
    "build": "npm --prefix kabul-safar-website run build",
    "start": "npm --prefix kabul-safar-website run start",
    "lint": "npm --prefix kabul-safar-website run lint"
  }
}
